{
  "$id": "https://www.breakthroughgenerations.org.uk/schemas/BreastTumourLink.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BreastTumourLink",
  "type": "object",
  "properties": {
    "StudyID": {
      "name": "StudyID",
      "description": "Unique 6-digit identifier for each participant in the study.",
      "type": [
        "number"
      ],
      "minLength": 6,
      "maxLength": 6
    },
    "TumourTracking": {
      "name": "TumourTracking",
      "description": "Tumour- and specimen-level pathology tracking records. Each item corresponds to a tissue block/slide linked to a tumour and pathology report.",
      "type": "array",
      "x-description": "Source: TumourTracking table in Pathology DB.",
      "minItems": 0,
      "items": {
        "type": "object",
        "properties": {
          "TrackID": {
            "name": "TrackID",
            "description": "Unique number to track the tumours entry in the tumourTracking table.",
            "type": [
              "integer",
              "null"
            ]
          },
          "RequestCount": {
            "name": "RequestCount",
            "description": "Number for tumour request.",
            "type": [
              "integer",
              "null"
            ]
          },
          "TrackSide": {
            "name": "TrackSide",
            "description": "Log of laterality for bilaterals",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 10
          },
          "Material": {
            "name": "Material",
            "description": "Type of material received from hospital",
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "Slide",
              "Block",
              null
            ],
            "enumDescriptions": [
              "Slide: Microscope slide",
              "Block: Tissue block",
              "null: Missing or invalid"
            ],
            "maxLength": 255
          },
          "MaterialID": {
            "name": "MaterialID",
            "description": "Hospital tumour block ID",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 255
          },
          "BoxNo": {
            "name": "BoxNo",
            "description": "Box number holding tumour block",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 255
          },
          "LabID": {
            "name": "LabID",
            "description": "Study ID and Labno combined",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 255
          },
          "LabNo": {
            "name": "LabNo",
            "description": "Laboratory accession number uniquely identifying a tissue block or slide.",
            "type": [
              "integer",
              "null"
            ]
          },
          "BlockSide": {
            "name": "BlockSide",
            "description": "Breast laterality from which the specimen originated.",
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "L",
              "R",
              null
            ],
            "enumDescriptions": [
              "L: Left",
              "R: Right",
              "null: None"
            ],
            "maxLength": 1
          },
          "TumourCount": {
            "name": "TumourCount",
            "description": "Sequential tumour identifier within a participant (used to distinguish multiple tumours recorded for the same participant; not a biological ordering).",
            "type": [
              "integer",
              "null"
            ],
            "x-description": "Sequentially coded 1..N within participant; dataset may contain multiple records per participant when multiple tumours are recorded."
          },
          "ReportCount": {
            "name": "ReportCount",
            "description": "Sequential identifier for pathology reports within a participant. Multiple tumours may relate to the same report.",
            "type": [
              "integer",
              "null"
            ],
            "x-description": "Sequentially coded 1..N within participant."
          },
          "BlockComments": {
            "name": "BlockComments",
            "description": "Comments on the block for lab purpose",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 255
          },
          "LabTracking": {
            "name": "LabTracking",
            "description": "Laboratory processing and digitisation metadata for the specimen.",
            "type": "array",
            "x-description": "Source: LabTracking table; linked by LabNo.",
            "minItems": 0,
            "items": {
              "type": "object",
              "properties": {
                "LabNo": {
                  "name": "LabNo",
                  "description": "Unique number for block or slide",
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "LabID": {
                  "name": "LabID",
                  "description": "Study ID and Labno combined",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 255
                },
                "LabSampleID": {
                  "name": "LabSampleID",
                  "description": "Unique sample ID",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 50
                },
                "LabSampleType": {
                  "name": "LabSampleType",
                  "description": "Histological preparation type of the laboratory specimen.",
                  "type": [
                    "string",
                    "null"
                  ],
                  "enum": [
                    "Core",
                    "ThickSection",
                    "ThinSection",
                    null
                  ],
                  "enumDescriptions": [
                    "Core: Core needle biopsy",
                    "ThickSection: Thick section",
                    "ThinSection: Thin section",
                    "null: None"
                  ],
                  "maxLength": 20
                },
                "LabSampleDate": {
                  "name": "LabSampleDate",
                  "description": "Date sample created",
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "maxLength": 23
                },
                "Scan": {
                  "name": "Scan",
                  "description": "Status of digital slide scanning for the first digitisation round.",
                  "type": [
                    "string",
                    "null"
                  ],
                  "x-description": "As recorded in the source system; originally described as completeness of 'Round1' scanned data.",
                  "maxLength": 50
                },
                "ScanDate": {
                  "name": "ScanDate",
                  "description": "Date of scan",
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "maxLength": 23
                },
                "LabComments": {
                  "name": "LabComments",
                  "description": "Comments from the lab",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 255
                },
                "ERIntensity": {
                  "name": "ERIntensity",
                  "description": "Pathology Lab ER intensity receptor result",
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "ER%Positive": {
                  "name": "ER%Positive",
                  "description": "Pathology Lab ER % positive recptor result",
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "Shipped": {
                  "name": "Shipped",
                  "description": "Sample shipped to collaborator",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 1
                },
                "DateShipped": {
                  "name": "DateShipped",
                  "description": "Date sample(s) shipped off site from BioDock",
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "maxLength": 23
                }
              },
              "additionalProperties": false
            }
          },
          "TMAs": {
            "name": "TMAs",
            "description": "Tissue Microarray (TMA) mapping records describing array identifiers and grid positions of sampled tissue cores.",
            "type": "array",
            "x-description": "Source: TMAMapping table; linked by LabNo.",
            "minItems": 0,
            "items": {
              "type": "object",
              "properties": {
                "ArrayIDFull": {
                  "name": "ArrayIDFull",
                  "description": "Full Tissue Microarray ID including section markers",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 100
                },
                "ArrayID": {
                  "name": "ArrayID",
                  "description": "Tissue Microarray ID",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 50
                },
                "ArrayNo": {
                  "name": "ArrayNo",
                  "description": "Short identifier distinguishing arrays within a TMA series (as recorded in the source system).",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 3
                },
                "ArraySister": {
                  "name": "ArraySister",
                  "description": "Identifier indicating a paired/replicate ('sister') TMA block constructed from the same source material.",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 1
                },
                "ArraySection": {
                  "name": "ArraySection",
                  "description": "Section number cut from the TMA block (as recorded in the source system).",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 3
                },
                "XAxis": {
                  "name": "XAxis",
                  "description": "Column coordinate of the core position within the TMA grid.",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 2
                },
                "YAxis": {
                  "name": "YAxis",
                  "description": "Row coordinate of the core position within the TMA grid.",
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "TMACoreID": {
                  "name": "TMACoreID",
                  "description": "Identifier of the individual tissue core placed at the specified TMA grid coordinate (may include orientation/control labels).",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 50
                },
                "TMAMarker": {
                  "name": "TMAMarker",
                  "description": "Receptor marker",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 20
                },
                "LabNo": {
                  "name": "LabNo",
                  "description": "Unique number for block or slide",
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "SampleType": {
                  "name": "SampleType",
                  "description": "Type of sample received - blood or urine",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 50
                },
                "TMAResult": {
                  "name": "TMAResult",
                  "description": "Quality check for TMAs with prefix BGS",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 100
                },
                "Annotation": {
                  "name": "Annotation",
                  "description": "Annotation for TMAs with prefix GS",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 10
                },
                "DonorCoreHeight": {
                  "name": "DonorCoreHeight",
                  "description": "Core height recorded by arrayer for TMAs with prefix GS excluding megas",
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "StatusLog": {
                  "name": "StatusLog",
                  "description": "Status of the TMA",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 1
                },
                "TMANotes": {
                  "name": "TMANotes",
                  "description": "Notes added fot Tissue MicroArray",
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 255
                },
                "TMADateAdded": {
                  "name": "TMADateAdded",
                  "description": "Date when TMA is added to the table",
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "maxLength": 23
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": [
    "StudyID"
  ],
  "additionalProperties": false
}